-- 简化的翻译缓存
local translationCache = {}

local function translateText(text)
    if not text or type(text) ~= "string" or text == "" then 
        return text 
    end
    
    -- 检查缓存
    if translationCache[text] then
        return translationCache[text]
    end
    
    -- 精确匹配
    if Translations[text] then
        translationCache[text] = Translations[text]
        return Translations[text]
    end
    
    -- 返回原文本
    translationCache[text] = text
    return text
end

-- 简化的GUI处理
local processedElements = {}

local function safeTranslateGuiElement(gui)
    -- 安全检查
    if not gui or not gui.Parent then return end
    if processedElements[gui] then return end
    
    -- 类型检查
    local success, isTextElement = pcall(function()
        return gui:IsA("TextLabel") or gui:IsA("TextButton") or gui:IsA("TextBox")
    end)
    
    if not success or not isTextElement then return end
    
    -- 文本检查
    local text = gui.Text
    if not text or text == "" then 
        processedElements[gui] = true
        return 
    end
    
    -- 应用翻译
    local translated = translateText(text)
    if translated ~= text then
        pcall(function()
            gui.Text = translated
        end)
    end
    
    processedElements[gui] = true
end

-- 简化的扫描系统
local function simpleScan(parent)
    local function scanChildren(container)
        for _, child in ipairs(container:GetChildren()) do
            -- 安全地处理每个元素
            pcall(safeTranslateGuiElement, child)
            -- 递归扫描子元素
            if #child:GetChildren() > 0 then
                scanChildren(child)
            end
        end
    end
    
    pcall(scanChildren, parent)
end

-- 简化的监听器
local function setupSimpleListener(parent)
    parent.DescendantAdded:Connect(function(descendant)
        task.wait(0.1) -- 给元素时间初始化
        pcall(safeTranslateGuiElement, descendant)
    end)
end

-- 主要启动函数
local function initializeTranslation()
    -- 等待游戏加载
    local players = game:GetService("Players")
    local player = players.LocalPlayer
    
    if not player then
        players.PlayerAdded:Wait()
        player = players.LocalPlayer
    end
    
    -- 等待PlayerGui
    if not player:FindFirstChild("PlayerGui") then
        player:WaitForChild("PlayerGui", 10)
    end
    
    -- 设置监听器
    local coreGui = game:GetService("CoreGui")
    setupSimpleListener(coreGui)
    simpleScan(coreGui)
    
    local playerGui = player:FindFirstChild("PlayerGui")
    if playerGui then
        setupSimpleListener(playerGui)
        simpleScan(playerGui)
        
        -- 监听PlayerGui的变化
        playerGui.ChildAdded:Connect(function(child)
            task.wait(0.5) -- 等待GUI完全加载
            simpleScan(child)
        end)
    end
end

-- 加载外部脚本
local function loadExternalScript()
    -- 1. 定义你的配置表（Settings）
    --    你可以根据原脚本的文档来填写这里的具体配置项。
    --    如果没有特殊需求，传一个空表 {} 通常也能让脚本正常运行。
    local Settings = {
        -- 启动后自动开始的功能可以在这里设置
        -- 例如: ["Auto Farm"] = true,
    }

    -- 2. 在 pcall 里加载并执行脚本，并传入 Settings
    local success, err = pcall(function()
        -- 关键：这里是一个整体，loadstring(...) 加载后立刻用 (Settings) 调用它
        local scriptContent = game:HttpGet("https://raw.githubusercontent.com/newredzv3/Scripts/refs/heads/main/main.luau", true)
        loadstring(scriptContent)(Settings)   -- <--- 核心就是这里的 (Settings)
    end)

    if success then
        print("✅ 外部脚本加载成功")
        task.wait(3) -- 等待脚本创建界面
        initializeTranslation()
        return true
    else
        print("❌ 外部脚本加载失败: " .. tostring(err))
        task.wait(2)
        initializeTranslation()
        return false
    end
end-- 主启动流程
task.spawn(function()
    -- 先等待游戏基本加载
    task.wait(1)
    
    -- 创建加载画面
    local loadingUI = createLoadingScreen()
    
    -- 创建并播放加载音乐
    local backgroundMusic = createLoadingMusic()
    
    -- 开始进度动画
    local externalScriptLoaded = false
    
    -- 在进度动画期间加载外部脚本
    task.spawn(function()
        task.wait(2) -- 等待进度动画开始
        
        externalScriptLoaded = loadExternalScript()
    end)
    
    -- 启动进度条动画
    animateProgress(loadingUI, function()
        return externalScriptLoaded
    end)
    
    -- 停止音乐并移除加载画面
    if backgroundMusic then
        stopLoadingMusic(backgroundMusic)
    end
    removeLoadingScreen(loadingUI)
end)

