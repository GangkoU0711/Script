-- 创建并播放加载音乐（修复版）
local function createLoadingMusic()
    local soundService = game:GetService("SoundService")
    
    -- 创建背景音乐
    local backgroundMusic = Instance.new("Sound")
    backgroundMusic.Name = "LoadingMusic"
    backgroundMusic.Volume = 0.3  -- 降低音量避免打扰
    backgroundMusic.Looped = true
    
    -- 尝试多个可能的音频源
    local audioSources = {
        -- 方法1: 使用已知可用的Roblox音频ID
        "rbxassetid://18482187377",  -- 舒缓的环境音乐
        "rbxassetid://9118468335",   -- 平静的背景音乐
        "rbxassetid://9047109572",   -- 轻音乐
        
        -- 方法2: 使用网络音频链接（如果Roblox允许）
        -- "https://example.com/your-music.mp3"
    }
    
    -- 尝试每个音频源，直到找到可用的
    for _, audioId in ipairs(audioSources) do
        local success = pcall(function()
            backgroundMusic.SoundId = audioId
            backgroundMusic.Parent = soundService
            backgroundMusic:Play()
            return true
        end)
        
        if success then
            print("✅ 音乐加载成功: " .. audioId)
            return backgroundMusic
        else
            print("❌ 音乐加载失败: " .. audioId)
        end
    end
    
    -- 如果所有音频都失败，返回nil
    print("⚠️ 所有音频源都失败，将无音乐运行")
    if backgroundMusic then
        backgroundMusic:Destroy()
    end
    return nil
end

-- 停止加载音乐（安全版）
local function stopLoadingMusic(backgroundMusic)
    if backgroundMusic and backgroundMusic.Parent then
        -- 淡出效果
        local tweenService = game:GetService("TweenService")
        local fadeOut = tweenService:Create(
            backgroundMusic,
            TweenInfo.new(1.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            {Volume = 0}
        )
        
        fadeOut:Play()
        
        -- 淡出完成后停止并移除音乐
        fadeOut.Completed:Connect(function()
            if backgroundMusic then
                backgroundMusic:Stop()
                backgroundMusic:Destroy()
            end
        end)
    end
end

-- 更新进度条
local function updateProgress(loadingUI, progress, status)
    if loadingUI and loadingUI.ProgressBar and loadingUI.ProgressText and loadingUI.StatusLabel then
        -- 更新进度条宽度
        loadingUI.ProgressBar.Size = UDim2.new(progress, 0, 1, 0)
        
        -- 更新百分比文字
        local percentage = math.floor(progress * 100)
        loadingUI.ProgressText.Text = percentage .. "%"
        
        -- 更新状态文字
        if status then
            loadingUI.StatusLabel.Text = status
        end
    end
end

-- 移除加载画面
local function removeLoadingScreen(loadingUI)
    if loadingUI and loadingUI.Screen and loadingUI.Screen.Parent then
        loadingUI.Screen:Destroy()
    end
end

-- 模拟进度动画
local function animateProgress(loadingUI, callback)
    local progress = 0
    local steps = {
        {progress = 0.1, status = "正在初始化..."},
        {progress = 0.2, status = "加载翻译系统..."},
        {progress = 0.4, status = "准备外部脚本..."},
        {progress = 0.6, status = "连接GitHub..."},
        {progress = 0.8, status = "下载脚本内容..."},
        {progress = 0.9, status = "执行脚本..."},
        {progress = 1.0, status = "加载完成!"}
    }
    
    for i, step in ipairs(steps) do
        progress = step.progress
        updateProgress(loadingUI, progress, step.status)
        
        -- 根据进度调整等待时间
        local waitTime = 0.5
        if i == 5 then  -- 下载步骤稍微长一点
            waitTime = 1.5
        elseif i == 6 then  -- 执行步骤也稍微长一点
            waitTime = 1.0
        end
        
        task.wait(waitTime)
        
        -- 检查是否需要提前结束（如果回调函数返回true）
        if callback and callback() then
            updateProgress(loadingUI, 1.0, "加载完成!")
            break
        end
    end
    
    task.wait(0.5) -- 最后停留0.5秒显示完成状态
end

